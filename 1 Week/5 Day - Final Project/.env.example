# Скопируй в .env и впиши свои ключи:  cp .env.example .env
# --- LLM (chat) ---
CHAT_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# --- Embeddings ---
EMB_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# --- Email (MailerSend) ---
MAILERSEND_KEY=mlsn.xxxxxxxxxxxxxxxxxxxx
# --- Получатель отчётов (свой адрес) ---
ADMIN_EMAIL=your-own@email.com
# --- PostgreSQL (история чата) ---
PGHOST=localhost
PGPORT=5433
PGDATABASE=yessenov_bot
# PGUSER=youruser     # по умолчанию — ОС-пользователь
# PGPASSWORD=secret   # для Homebrew-trust не нужен
# Либо одной строкой:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
